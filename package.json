{
  "name": "ipo-hero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_USE_MOCK=true vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/ingest/run-ingestion.ts",
    "ingest:force": "tsx scripts/ingest/run-ingestion.ts --force",
    "validate:data": "tsx scripts/ingest/validate-output.ts",
    "review:merge": "tsx scripts/ingest/merge-reviewed.ts",
    "brief": "tsx scripts/brief/generate-brief.ts",
    "validate:brief": "tsx scripts/brief/validate-brief.ts"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.108.0",
    "@vitejs/plugin-react": "latest",
    "cheerio": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "latest",
    "tw-animate-css": "^1.4.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.60.1",
    "vite": "latest"
  }
}
